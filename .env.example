# 复制为 .env 后修改（勿提交真实密钥到仓库）
PORT=3000
NODE_ENV=production
SESSION_SECRET=请替换为长随机字符串
# 可选：会话 Cookie 最长存活（毫秒），默认约 400 天；每次访问会自动顺延（rolling）。手动点退出会立即清除登录。
# SESSION_MAX_AGE_MS=
# 反向代理 HTTPS 时设为 1，便于 Cookie Secure 与 IP 识别
TRUST_PROXY=1
# 可选：站点对外根地址（无尾斜杠）。视频等会先上传到本机 uploads/，反推需把 /uploads/... 拼成公网 URL 供百炼拉取；反代未传 X-Forwarded-Host 或仅用 IP 访问时，请填 https://你的域名
PUBLIC_SITE_URL=
# 生产环境若前端为 HTTP 内网调试，可设为 0 关闭 Secure Cookie（默认生产为 1）
COOKIE_SECURE=1
# 首次建库时写入「上传缓存自动清理」默认值（之后请在管理后台控制台修改）
UPLOAD_CACHE_RETENTION_HOURS=8
UPLOAD_CACHE_CLEAN_INTERVAL_MINUTES=30
# 资产生成 /api/generate/image：Nano Banana 上游超时（毫秒），默认 300000（5 分钟）。4K+宫格仍慢可调到 480000～600000。
# NANO_BANANA_FETCH_TIMEOUT_MS=480000
# Node HTTP 单请求最长（毫秒），默认 max(600000, 上游+120000)。须 ≤ 反代 proxy_read_timeout，否则仍会出现 504 非 JSON。
# HTTP_SERVER_REQUEST_TIMEOUT_MS=600000
# 若 Nginx 反代出现 504：在对应 location 增加 proxy_read_timeout 600s; proxy_send_timeout 600s;
# 无限画布已改为「先 POST 拿 job_id 再轮询 /api/generate/image/status」，一般不再受长寿 POST 的 504 影响；任务状态仅存内存，多进程/多机需另行改造。
