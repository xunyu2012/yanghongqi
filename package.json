{
  "name": "xunyu-ai",
  "version": "1.0.0",
  "description": "讯语AI-v1 前后端一体化服务",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "backup": "powershell -ExecutionPolicy Bypass -File ./backup.ps1",
    "backup:remote": "powershell -ExecutionPolicy Bypass -File ./backup-remote.ps1",
    "deploy": "powershell -ExecutionPolicy Bypass -File ./deploy.ps1",
    "deploy:nobackup": "powershell -ExecutionPolicy Bypass -File ./deploy.ps1 -SkipBackup"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.6.0",
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "jsonrepair": "^3.12.0",
    "multer": "^1.4.5-lts.1"
  }
}
